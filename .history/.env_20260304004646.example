# App pública (PWA / Capacitor)
NEXT_PUBLIC_APP_URL=

# Supabase (obtener en https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Emails de admin (separados por coma). Si la tabla profiles falla (ej. 500), el acceso admin se decide por este valor.
# Ejemplo: NEXT_PUBLIC_ADMIN_EMAILS=admin@comunidad.com,otro@admin.com
NEXT_PUBLIC_ADMIN_EMAILS=
