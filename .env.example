# Copiar a .env.local (desarrollo) o cargar en Vercel → Settings → Environment Variables

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Obligatorio en producción para permalinks/API de publicidad y lecturas server-side fiables
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL pública del sitio (compartir enlaces de publicidades). En Vercel suele coincidir con el dominio del proyecto.
NEXT_PUBLIC_APP_URL=https://www.comunidaddesantotome.com.ar
