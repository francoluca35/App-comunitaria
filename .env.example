# App pública (PWA / Capacitor)
NEXT_PUBLIC_APP_URL=

# Supabase (obtener en https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# Necesario para guardar suscripciones push y webhook (Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (alertas con app en segundo plano). Generar: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: del contacto del sitio (requerido por el estándar Web Push)
VAPID_SUBJECT=mailto:admin@tudominio.com

# Mismo valor en header x-webhook-secret (o Authorization: Bearer …) del webhook. Guía: docs/PUSH_WEBHOOK_SETUP.md
PUSH_WEBHOOK_SECRET=
