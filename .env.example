# App pública (PWA / Capacitor)
NEXT_PUBLIC_APP_URL=

# Supabase (obtener en https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# Necesaria para subir foto de perfil (Storage). Supabase → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
